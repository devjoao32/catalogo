# Backend production environment example.
# Copy the values into your hosting provider/SAM parameters, not into Git.

CATALOG_ENABLE_API_DOCS=false
CATALOG_CORS_ALLOW_ORIGINS=https://catalogo.example.com
CATALOG_CORS_ALLOW_CREDENTIALS=true

# Generate unique secrets with at least 32 characters.
CATALOG_SESSION_SECRET=replace-with-a-long-random-secret-minimum-32-chars
CATALOG_REPRESENTATIVE_JWT_SECRET=replace-with-a-different-long-random-secret
CATALOG_SESSION_COOKIE_SECURE=true
CATALOG_SESSION_MAX_AGE_SECONDS=43200

# Admin access. Prefer hashed users in reports/admin_users.json for local deployments,
# or configure a password in the secret manager/runtime environment.
CATALOG_ADMIN_LOGIN_EMAIL=admin@example.com
CATALOG_ADMIN_LOGIN_PASSWORD=replace-with-admin-password

# Representative access. Prefer managed representatives through the admin panel.
CATALOG_REPRESENTATIVE_JWT_EXPIRES_MINUTES=720

# ERP/catalog data.
CATALOG_ERP_STRICT_MODE=true
CATALOG_ERP_AUTO_DISCOVERY=false
CATALOG_ERP_MAX_UPLOAD_BYTES=10485760

# Product media in production.
CATALOG_S3_MEDIA_BUCKET=your-catalog-media-bucket
CATALOG_S3_MEDIA_PREFIX=produtos/
CATALOG_S3_MEDIA_PRESIGNED_URLS=false

# Optional Google Drive fallback.
CATALOG_GOOGLE_DRIVE_FOLDER_ID=
CATALOG_GOOGLE_DRIVE_API_KEY=
CATALOG_GOOGLE_DRIVE_RECURSIVE=true
CATALOG_GOOGLE_DRIVE_MAX_DEPTH=4
